      "text": "How the PM (Priya) uses TCR — the right way",
      "fontSize": 18, "fontFamily": 1, "fontStyle": 1,
      "strokeColor": "#1A1A1A", "backgroundColor": "transparent", "fillStyle": "solid",
      "roughness": 0, "opacity": 100
    },

