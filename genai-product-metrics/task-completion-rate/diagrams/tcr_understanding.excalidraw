    {
      "id": "br1-bg",
      "type": "rectangle",
      "x": 40, "y": 776, "width": 430, "height": 280,
      "backgroundColor": "#ffffff", "strokeColor": "#A32D2D",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
